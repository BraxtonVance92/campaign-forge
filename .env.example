# Copy to .env and fill in real values locally. Never commit .env (already
# gitignored). This file documents variable NAMES only -- no values.

# Required for real analysis calls (docs/ops/ACTIVE_WORK_PACKET.md CF-RUN-001
# / CF-VERIFY-001). Without this, analysis is honestly reported as blocked.
GMI_API_KEY=

# Required for real Backblaze B2 persistence. Without all four, storage
# falls back to local disk (clearly labeled in the running app as
# "local-disk-fallback", never presented as B2).
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=

# Optional: where local-disk-fallback storage writes files when B2 isn't
# configured. Defaults to ./.local_storage if unset.
LOCAL_STORAGE_ROOT=
